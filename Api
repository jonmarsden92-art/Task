// Get all active tasks (for workers)
app.get(’/api/tasks’, (req, res) => {
const { category, minReward, maxReward, sortBy } = req.query;

let filteredTasks = tasks.filter(task => task.status === ‘active’);

// Apply filters
if (category) {
filteredTasks = filteredTasks.filter(task =>
task.category.toLowerCase().includes(category.toLowerCase())
);
}

if (minReward) {
filteredTasks = filteredTasks.filter(task => task.reward >= parseFloat(minReward));
}

if (maxReward) {
filteredTasks = filteredTasks.filter(task => task.reward <= parseFloat(maxReward));
}

// Sort tasks
if (sortBy === ‘reward_desc’) {
filteredTasks.sort((a, b) => b.reward - a.reward);
} else if (sortBy === ‘reward_asc’) {
filteredTasks.sort((a, b) => a.reward - b.reward);
} else if (sortBy === ‘newest’) {
filteredTasks.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
}

res.json({ tasks: filteredTasks });
});

