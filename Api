// Submit task completion
app.post(’/api/tasks/:id/submit’, authenticateToken, upload.array(‘files’, 3), (req, res) => {
try {
if (req.user.userType !== ‘worker’) {
return res.status(403).json({ error: ‘Only workers can submit tasks’ });
}

```
const taskId = parseInt(req.params.id);
const task = tasks.find(t => t.id === taskId);

if (!task) {
  return res.status(404).json({ error: 'Task not found' });
}

if (task.completedSlots >= task.totalSlots) {
  return res.status(400).json({ error: 'Task is full' });
}

// Check if user already submitted this task
const existingSubmission = submissions.find(s => 
  s.taskId === taskId && s.workerId === req.user.userId
);

if (existingSubmission) {
  return res.status(400).json({ error: 'You have already submitted this task' });
}

const submission = {
  id: generateId(),
  taskId,
  workerId: req.user.userId,
  data: req.body,
  files: req.files ? req.files.map(f => f.filename) : [],
  status: 'pending',
  submittedAt: new Date()
};

submissions.push(submission);

// Update task completion count
task.completedSlots += 1;

res.status(201).json({
  message: 'Task submitted successfully',
  submission: {
    id: submission.id,
    status: submission.status,
    submittedAt: submission.submittedAt
  }
});
```

} catch (error) {
res.status(500).json({ error: ‘Server error submitting task’ });
}
});

// Get user’s submissions
app.get(’/api/submissions’, authenticateToken, (req, res) => {
const userSubmissions = submissions.filter(s => s.workerId === req.user.userId);

const enrichedSubmissions = userSubmissions.map(submission => {
const task = tasks.find(t => t.id === submission.taskId);
return {
…submission,
task: task ? {
title: task.title,
reward: task.reward,
category: task.category
} : null
};
});

res.json({ submissions: enrichedSubmissions });
});

// Approve/Reject submission (business users only)
app.put(’/api/submissions/:id/review’, authenticateToken, (req, res) => {
try {
if (req.user.userType !== ‘business’) {
return res.status(403).json({ error: ‘Only business users can review submissions’ });
}

```
const { status, feedback } = req.body; // status: 'approved' or 'rejected'
const submissionId = parseInt(req.params.id);

const submission = submissions.find(s => s.id === submissionId);
if (!submission) {
  return res.status(404).json({ error: 'Submission not found' });
}

const task = tasks.find(t => t.id === submission.taskId);
if (task.createdBy !== req.user.userId) {
  return res.status(403).json({ error: 'You can only review your own tasks' });
}

submission.status = status;
submission.feedback = feedback;
submission.reviewedAt = new Date();

// If approved, pay the worker
if (status === 'approved') {
  const worker = users.find(u => u.id === submission.workerId);
  if (worker) {
    worker.balance += task.reward;
    worker.completedTasks += 1;

    // Create transaction record
    transactions.push({
      id: generateId(),
      type: 'task_payment',
      userId: worker.id,
      amount: task.reward,
      description: `Payment for: ${task.title}`,
      createdAt: new Date()
    });

    // Platform commission
    transactions.push({
      id: generateId(),
      type: 'platform_commission',
      userId: 'platform',
      amount: calculateCommission(task.reward),
      description: `Commission from: ${task.title}`,
      createdAt: new Date()
    });
  }
}

res.json({
  message: `Submission ${status} successfully`,
  submission
});
```

} catch (error) {
res.status(500).json({ error: ‘Server error reviewing submission’ });
}
});

