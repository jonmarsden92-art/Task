res.json({
analytics: {
totalUsers,
totalTasks,
totalSubmissions,
totalRevenue: totalRevenue.toFixed(2),
activeWorkers,
activeBusinesses,
averageTaskReward: tasks.reduce((sum, t) => sum + t.reward, 0) / tasks.length || 0
}
});
});

